<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".SendPictureActivity">

    <!-- Upload button -->
    <Button
        android:id="@+id/buttonUpload"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Upload foto"
        android:onClick="onUploadClick"
        android:backgroundTint="@color/green_primary"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBanner"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonUpload"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Progress text -->
    <TextView
        android:id="@+id/progressText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Stav"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/progressBanner"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/progressFileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="File name"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/progressBanner"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Message -->
    <TextView
        android:id="@+id/textMsgLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/progressText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Output -->
    <TextView
        android:id="@+id/textVystup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Stav:"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textMsgLabel"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Buttons group -->
    <LinearLayout
        android:id="@+id/buttonGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/textVystup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Exit -->
        <Button
            android:id="@+id/buttonExit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/exit"
            android:onClick="onExitClick"
            android:backgroundTint="@color/red_primary"
            android:textColor="@color/white"/>

        <!-- Galeria -->
        <Button
            android:id="@+id/buttonGaleria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/geleria"
            android:onClick="onGaleriaClick"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/blue_soft"
            android:textColor="@color/white"/>

        <!-- Daikin -->
        <Button
            android:id="@+id/buttonDaikin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daikin"
            android:onClick="onDaikinClick"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/teal_soft"
            android:textColor="@color/white"/>

        <!-- Fondy -->
        <Button
            android:id="@+id/buttonFondy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fondy"
            android:onClick="onFondyClick"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/purple_soft"
            android:textColor="@color/white"/>

        <!-- Pohyby -->
        <Button
            android:id="@+id/buttonMotion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pohyby"
            android:onClick="onMotionClick"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/amber_soft"
            android:textColor="@color/white"/>

        <!-- Mail -->
        <Button
            android:id="@+id/buttonMail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pošta"
            android:onClick="onMailClick"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/orange_soft"
            android:textColor="@color/white"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>